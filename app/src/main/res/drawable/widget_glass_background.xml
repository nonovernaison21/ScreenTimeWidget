<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base translucide type "verre" -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Léger reflet en haut pour l'effet glossy -->
    <item android:top="0dp" android:bottom="60dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Bordure fine type verre -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
